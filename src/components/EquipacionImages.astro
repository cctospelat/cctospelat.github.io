---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12 mb-16">
  <div class="relative overflow-hidden rounded-2xl">
    <div class="aspect-square">
      <img 
        src="/fotos/content/1_club/equip1.png" 
        alt="Equipación frontal C.C. Tospelat" 
        class="w-full h-full object-contain p-4"
      />
    </div>
    <div class="absolute inset-0 flex items-end p-6">
      <p class="text-black font-bold text-lg">{t('equipacion.training')}</p>
    </div>
  </div>

  <div class="relative overflow-hidden rounded-2xl">
    <div class="aspect-square">
      <img
        src="/fotos/content/1_club/equip2.png"
        alt="Equipación trasera C.C. Tospelat"
        class="w-full h-full object-contain p-4"
      />
    </div>
    <div class="absolute inset-0 flex items-end p-6">
      <p class="text-black font-bold text-lg">{t('equipacion.competition')}</p>
    </div>
  </div>
</div>

<style>
  /* Custom glassmorphism or other premium effects can be added here if needed */
</style>

---
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
---

<div class="flex space-x-3 items-center border-l border-slate-800 pl-8">
  <a href="/website/" class={`group relative w-6 h-4 overflow-hidden rounded-sm border border-slate-800 hover:border-slate-600 transition-all ${lang === 'es' ? 'border-red-500 ring-1 ring-red-500' : ''}`} title="Español">
    <img src="/website/logos/flags/es.svg" alt="Español" class="w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all" />
  </a>
  <a href="/website/ca/" class={`group relative w-6 h-4 overflow-hidden rounded-sm border border-slate-800 hover:border-slate-600 transition-all ${lang === 'ca' ? 'border-red-500 ring-1 ring-red-500' : ''}`} title="Valencià">
    <img src="/website/logos/flags/ca.svg" alt="Valencià" class="w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all" />
  </a>
  <a href="/website/en/" class={`group relative w-6 h-4 overflow-hidden rounded-sm border border-slate-800 hover:border-slate-600 transition-all ${lang === 'en' ? 'border-red-500 ring-1 ring-red-500' : ''}`} title="English">
    <img src="/website/logos/flags/en.svg" alt="English" class="w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all" />
  </a>
  <a href="/website/fr/" class={`group relative w-6 h-4 overflow-hidden rounded-sm border border-slate-800 hover:border-slate-600 transition-all ${lang === 'fr' ? 'border-red-500 ring-1 ring-red-500' : ''}`} title="Français">
    <img src="/website/logos/flags/fr.svg" alt="Français" class="w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all" />
  </a>
</div>

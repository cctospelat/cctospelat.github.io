---
import { getCollection, render } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const clubEntries = await getCollection('club', ({ id }) => id.split('/')[0] === lang);
const sobreNosotrosEntry = clubEntries.find(entry => entry.id === `${lang}/1_club/sobre-nosotros`);
const compromisoEntry = clubEntries.find(entry => entry.id === `${lang}/1_club/compromiso`);
const coloresEntry = clubEntries.find(entry => entry.id === `${lang}/1_club/nuestra-piel`);

if (!sobreNosotrosEntry || !compromisoEntry || !coloresEntry) {
  throw new Error(`Missing club data for language ${lang}. Ensure files exist in src/content/${lang}/1_club/`);
}

const { Content: SobreNosotrosContent } = await render(sobreNosotrosEntry);
const { Content: CompromisoContent } = await render(compromisoEntry);
const { Content: ColoresContent } = await render(coloresEntry);

const hero = sobreNosotrosEntry;

import EquipacionImages from './EquipacionImages.astro';
import SponsorsCarousel from './SponsorsCarousel.astro';
---

<section id="inicio" class="relative pt-14 lg:pt-24 overflow-hidden bg-white">
  {/* Background Decoration */}
  <div class="absolute inset-0 overflow-hidden -z-10 pointer-events-none">
    <div class="absolute -top-32 -right-32 w-[500px] h-[500px] bg-red-500 rounded-full opacity-[0.04]"></div>
  </div>

  {/* Text content — centrado */}
  <div class="max-w-4xl mx-auto px-5 sm:px-6 lg:px-8 relative text-center pb-12">
    {/* Badge */}
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-500 text-white text-sm font-bold mb-8 uppercase tracking-widest shadow-lg shadow-red-500/30">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M13.49 5.48c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm-3.6 13.9l1-4.4 2.1 2v6h2v-7.5l-2.1-2 .6-3c1.3 1.5 3.3 2.5 5.5 2.5v-2c-1.9 0-3.5-1-4.3-2.4l-1-1.6c-.4-.6-1-1-1.7-1-.3 0-.5.1-.8.1l-5.2 2.2v4.7h2v-3.4l1.8-.7-1.6 8.1-4.9-1-.4 2 7 1.4z"/>
      </svg>
      {t('hero.badge')} {new Date().getFullYear()}
    </div>

    {/* Title */}
    <h1 class="font-display font-black uppercase tracking-wide leading-none mb-6">
      <div class="text-5xl lg:text-7xl text-slate-900 mb-1">{t('hero.title')}</div>
      <div class="text-4xl lg:text-6xl bg-gradient-to-r from-red-500 to-rose-500 bg-clip-text text-transparent mb-1">{t('hero.subtitle_part')}</div>
      <div class="text-4xl lg:text-6xl text-slate-700">{t('hero.subtitle_part2')}</div>
    </h1>

    <p class="text-lg lg:text-xl text-slate-600 leading-relaxed mb-8 max-w-2xl mx-auto">
      {hero.data.subtitle}
    </p>

    {/* <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#contacto" class="inline-flex justify-center items-center gap-2 px-8 py-4 text-base font-bold rounded-full text-white bg-red-500 hover:bg-slate-900 shadow-xl shadow-red-500/25 transition-all duration-300 hover:-translate-y-1 uppercase tracking-wider font-display">
        {t('hero.cta.join')}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div> */}
  </div>

  {/* Foto a ancho completo */}
  {hero.data.image && (
    <div class="relative w-full">
      <img
        src={hero.data.image}
        alt="C.C. Tospelat en acción"
        class="w-full h-auto object-contain"
      />
      <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-slate-900/70 to-transparent px-8 py-6 flex items-end justify-between">
        <div class="text-white">
          <p class="font-display font-bold text-xl lg:text-2xl uppercase tracking-wide">{hero.data.title}</p>
          <p class="text-sm text-slate-300">{t('hero.passion')}</p>
        </div>
        <div class="bg-red-500 text-white rounded-2xl px-4 py-3 shadow-xl shadow-red-500/30">
          <p class="font-display font-black text-2xl uppercase leading-none">#Tospelat</p>
        </div>
      </div>
    </div>
  )}
</section>

{/* Club Description Section */}
<section id="club" class="py-24 bg-white relative border-t border-slate-100">
  <div class="max-w-4xl mx-auto px-5 sm:px-6 lg:px-8 text-center">

    <div class="mb-16">
      <span class="text-red-500 font-display font-bold uppercase tracking-[0.3em] text-sm">{t('nav.club')}</span>
      <h2 class="font-display font-black uppercase tracking-wide text-4xl lg:text-5xl text-slate-800 mt-1 mb-4">{t('club.title')}</h2>
      <div class="w-12 h-1 bg-red-500 mx-auto"></div>
    </div>
    <div class="club-prose mx-auto max-w-2xl text-center mb-20">
      <SobreNosotrosContent />
    </div>

    <div class="mb-16">
      <span class="text-red-500 font-display font-bold uppercase tracking-[0.3em] text-sm">{t('nav.club')}</span>
      <h2 class="font-display font-black uppercase tracking-wide text-4xl lg:text-5xl text-slate-800 mt-1 mb-4">{t('club.commitment')}</h2>
      <div class="w-12 h-1 bg-red-500 mx-auto"></div>
    </div>
    <div class="club-prose mx-auto max-w-2xl text-center mb-20">
      <CompromisoContent />
    </div>

    <div class="mb-16">
      <span class="text-red-500 font-display font-bold uppercase tracking-[0.3em] text-sm">{t('nav.club')}</span>
      <h2 class="font-display font-black uppercase tracking-wide text-4xl lg:text-5xl text-slate-800 mt-1 mb-4">{t('club.skin')}</h2>
      <div class="w-12 h-1 bg-red-500 mx-auto"></div>
    </div>
    <div class="club-prose mx-auto max-w-2xl text-center mb-12">
      <ColoresContent />
    </div>

    <EquipacionImages />
  </div>
</section>

<SponsorsCarousel />


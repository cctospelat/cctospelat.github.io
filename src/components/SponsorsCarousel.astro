---
import { getCollection, render } from 'astro:content';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const entries = await getCollection('colaboradores', ({ id }) => id.split('/')[0] === lang);
const entry = entries[0];

if (!entry) {
  throw new Error(`Missing colaboradores data for language ${lang}. Ensure file exists in src/content/${lang}/2_colaboradores/`);
}

const { title, category, sponsors } = entry.data;
const { Content } = await render(entry);
---

<section id="patrocinadores" class="py-24 bg-slate-50 relative">
  <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="text-red-500 font-display font-bold uppercase tracking-[0.3em] text-sm">{category}</span>
      <h2 class="font-display font-black uppercase tracking-wide text-4xl lg:text-5xl text-slate-800 mt-1 mb-4">{title}</h2>
      <div class="w-12 h-1 bg-red-500 mx-auto"></div>
    </div>
  </div>

  <div class="relative w-full overflow-hidden">
    {/* Fade masks */}
    <div class="absolute inset-y-0 left-0 w-20 bg-gradient-to-r from-slate-50 to-transparent z-10"></div>
    <div class="absolute inset-y-0 right-0 w-20 bg-gradient-to-l from-slate-50 to-transparent z-10"></div>

    <div class="marquee-scroller-track flex items-center">
      {/* Set 1 */}
      <div class="flex items-center shrink-0">
        {sponsors.map((sponsor) => (
          <div class="mx-12 sm:mx-20 flex-shrink-0">
            <img
              src={sponsor.logo}
              alt={sponsor.name}
              class="h-20 sm:h-24 w-auto object-contain"
            />
          </div>
        ))}
      </div>
      {/* Set 2 (identical for seamless loop) */}
      <div class="flex items-center shrink-0" aria-hidden="true">
        {sponsors.map((sponsor) => (
          <div class="mx-12 sm:mx-20 flex-shrink-0">
            <img
              src={sponsor.logo}
              alt={sponsor.name}
              class="h-20 sm:h-24 w-auto object-contain"
            />
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="club-prose max-w-2xl mx-auto px-5 sm:px-6 lg:px-8 mt-14 text-center">
    <Content />
  </div>

  <div class="max-w-sm mx-auto px-5 sm:px-6 lg:px-8 mt-12">
    <div class="rounded-2xl overflow-hidden shadow-lg">
      <img
        src="/fotos/content/2_colaboradores/sponsor1.webp"
        alt="Acuerdo de colaboración con Clínica Balaguer"
        class="w-full object-cover"
      />
    </div>
  </div>
</section>

<style is:inline>
  @keyframes marquee-movement-loop {
    0%   { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-50%, 0, 0); }
  }

  .marquee-scroller-track {
    display: inline-flex !important;
    width: max-content !important;
    animation: marquee-movement-loop 35s linear infinite !important;
    will-change: transform;
    padding: 1rem 0;
  }

  .marquee-scroller-track img {
    display: block;
    image-rendering: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-scroller-track {
      animation: none !important;
      overflow-x: auto;
      width: 100% !important;
      justify-content: center;
      flex-wrap: wrap;
      gap: 2rem;
    }
  }

  @media (max-width: 640px) {
    .marquee-scroller-track {
      animation-duration: 20s !important;
    }
  }
</style>

---
import '../styles/global.css';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
	title: string;
	description?: string;
}

const { title, description = t('layout.description') } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/x-icon" href="/website/favicon.ico" />
		<link rel="icon" type="image/svg+xml" href="/website/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/website/favicon-32x32.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/website/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | C.C. Tospelat</title>
		<meta name="description" content={description} />
	</head>
	<body class="flex flex-col min-h-screen bg-slate-50">
		<slot />
	</body>
</html>


---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import HeroPresentation from '../../components/HeroPresentation.astro';
import EntrenamientoSection from '../../components/Entrenamiento.astro';
import NewsSection from '../../components/NewsSection.astro';
import CalendarSection from '../../components/CalendarSection.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'ca' } },
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
  ];
}
---

<Layout title="C.C. Tospelat Moncada">
  <Header />
  <main>
    <HeroPresentation />
    <EntrenamientoSection />
    <NewsSection />
    <CalendarSection />
  </main>
  <Footer />
</Layout>
